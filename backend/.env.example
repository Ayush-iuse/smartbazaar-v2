# SmartBazaar V3 - Backend Environment Variables Template (.env.example)

# --- Database Connection URL ---
DATABASE_URL=postgresql+psycopg://postgres:password@host:5432/postgres?sslmode=require

# --- Supabase Integration Keys ---
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- AI APIs Keys ---
OPENAI_API_KEY=
GEMINI_API_KEY=

# --- Security & Core ---
JWT_SECRET=supersecretkeychangeinproduction12345!
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Cloudinary Asset Management ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
