# Application Database URL (PostgreSQL default for Docker Compose)
DATABASE_URL=postgresql://postgres:postgres_secure_pass@db:5432/smartbazaar

# Database Local Direct URL (for running scripts/tests locally outside Docker)
# DATABASE_URL=postgresql://postgres:postgres_secure_pass@localhost:5432/smartbazaar

# JWT Secret Key for token signing and authentication
JWT_SECRET=supersecretkeychangeinproduction12345!

# OpenAI API Key (leave empty to trigger rule-based local fallback mode)
OPENAI_API_KEY=
