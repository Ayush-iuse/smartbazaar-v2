# -----------------------------------------------------------------------------
# SmartBazaar V2 - Global Environment Configuration Guide (.env.example)
# Copy this file to '.env' for local configuration.
# -----------------------------------------------------------------------------

# --- System Server Port ---
PORT=8000

# --- Database Integration ---
# Local SQLite fallback: "sqlite:///./db.sqlite3"
# Cloud Postgres examples: Neon, Supabase, Railway
DATABASE_URL=postgresql+psycopg://postgres:smartbazaar010405@db.hzonllawscqnjalxrnvo.supabase.co:5432/postgres?sslmode=require
DB_SSL_MODE=require

# --- Caching, Limits & User Presence (Upstash or Redis Container) ---
# Format: rediss://:password@host:port (Use rediss:// protocol for TLS on Upstash)
# Leave empty to automatically fall back to InMemoryRedis.
REDIS_URL=
REDIS_HOST=db

# --- Security & Credentials ---
# Generate a cryptographically secure key for JWT tokens (e.g. openssl rand -hex 32)
JWT_SECRET=supersecretkeychangeinproduction12345!
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Cloudinary Remote Media Upload Storage ---
# Leave these empty to fall back to local disk storage under backend/uploads/
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- OpenAI API Key ---
# Leave empty to trigger rule-based local fallback mode
OPENAI_API_KEY=

# --- CORS Configurations ---
# Comma-separated list of allowed origins (no trailing slashes)
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
